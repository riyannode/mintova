# App
NEXT_PUBLIC_APP_NAME=Mintova
NEXT_PUBLIC_APP_ENV=testnet
NEXT_PUBLIC_ENABLE_MAINNET=false

# WalletConnect optional
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Circle UCW / Wallet APIs - server-side only
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_APP_ID=
CIRCLE_WALLET_SET_ID=

# AI - server-side only
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# RPC URLs - server-side or safe public testnet RPC only
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
AVALANCHE_FUJI_RPC_URL=
ARC_TESTNET_RPC_URL=

# Feature flags
ENABLE_AGENT=true
ENABLE_SWAP=false
ENABLE_CROSSCHAIN_SWAP=false
ENABLE_MAINNET=false
