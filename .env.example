# App
NEXT_PUBLIC_APP_NAME=Mintova
NEXT_PUBLIC_APP_ENV=testnet
NEXT_PUBLIC_ENABLE_MAINNET=false

# Circle UCW — client-side (used by App Kit / UCW SDK in browser)
NEXT_PUBLIC_CIRCLE_APP_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# WalletConnect optional
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Circle UCW / Wallet APIs — server-side only
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
# CIRCLE_ENTITY_SECRET is for DCW admin operations only.
# It is NOT used for user bridge execution.
# User bridge execution requires UCW user signing (not wired yet — Phase 4 execution disabled).
CIRCLE_ENTITY_SECRET=

# AI — server-side only
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# RPC URLs — server-side or safe public testnet RPC only
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
AVALANCHE_FUJI_RPC_URL=
ARC_TESTNET_RPC_URL=

# Feature flags
ENABLE_AGENT=true
ENABLE_SWAP=false
ENABLE_CROSSCHAIN_SWAP=false
ENABLE_MAINNET=false
